<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Hermes</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700&family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;1,9..144,500&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    /* paper & ink */
    --paper: #F6F1E7;
    --paper-shade: #EDE4D0;
    --paper-card: #FBF8F1;
    --rule: #D8CBAE;
    --ink: #22201B;
    --ink-soft: #6F6656;

    /* one accent per agent / outcome, echoed everywhere that agent shows up */
    --slot-blue: #2E5C88;   /* triage · processing */
    --ochre: #9C6B2E;       /* specialist · drafting */
    --postal-green: #3F7A4E;/* reviewer · approved */
    --stamp-red: #B5402F;   /* reviewer · needs revision / urgent */
    --kraft: #8C6A3F;       /* digest · held for digest */

    --shadow: 0 1px 2px rgba(34,32,27,0.06), 0 6px 16px rgba(34,32,27,0.05);
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    font-family: "IBM Plex Sans", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 15px;
    background-image:
      linear-gradient(var(--rule) 1px, transparent 1px);
    background-size: 100% 32px;
    background-attachment: local;
  }

  code, .mono { font-family: "IBM Plex Mono", ui-monospace, Menlo, monospace; }

  header {
    padding: 22px 32px;
    border-bottom: 2px solid var(--ink);
    background: var(--paper);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .brand { display: flex; align-items: center; gap: 14px; }
  .logomark {
    width: 40px; height: 40px; flex: none;
    border-radius: 50%;
    border: 2px solid var(--ink);
    position: relative;
    display: flex; align-items: center; justify-content: center;
    transform: rotate(-8deg);
  }
  .logomark::after {
    content: "";
    position: absolute; inset: 4px;
    border: 1px dashed var(--ink);
    border-radius: 50%;
  }
  .logomark span {
    font-family: "IBM Plex Mono", monospace;
    font-size: 10px; font-weight: 600;
    letter-spacing: 0.02em;
  }
  header h1 {
    font-family: "Cinzel", "Fraunces", Georgia, serif;
    font-size: 26px;
    font-weight: 600;
    margin: 0;
    letter-spacing: 0.04em;
  }

  .controls { display: flex; gap: 10px; }
  button {
    font-family: "IBM Plex Sans", sans-serif;
    background: var(--ink);
    color: var(--paper);
    border: 1.5px solid var(--ink);
    padding: 10px 18px;
    border-radius: 3px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform 0.08s ease, opacity 0.15s ease;
  }
  button:hover:not(:disabled) { transform: translateY(-1px); }
  button:active:not(:disabled) { transform: translateY(0); }
  button.secondary {
    background: transparent;
    border: 1.5px solid var(--ink);
    color: var(--ink);
  }
  button:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
  button:focus-visible, a:focus-visible {
    outline: 2px solid var(--slot-blue);
    outline-offset: 2px;
  }

  main {
    display: grid;
    grid-template-columns: 1fr 360px;
    align-items: start;
  }
  .left { padding: 28px 32px; }
  .right {
    padding: 28px 24px;
    border-left: 2px solid var(--ink);
    min-height: calc(100vh - 89px);
    display: flex;
    flex-direction: column;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin: 0 0 16px;
    gap: 12px;
  }
  .trace-link {
    background: none;
    border: none;
    padding: 0;
    font-family: "IBM Plex Mono", monospace;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: none;
    color: var(--slot-blue);
    text-decoration: underline dotted;
    text-underline-offset: 3px;
    cursor: pointer;
  }
  .trace-link:hover { color: var(--ink); }
  .trace-link .dot {
    display: inline-block; width: 6px; height: 6px; border-radius: 50%;
    background: var(--slot-blue); margin-right: 5px;
  }
  h2 {
    font-family: "Fraunces", Georgia, serif;
    font-size: 17px;
    font-weight: 600;
    margin: 0;
    letter-spacing: -0.005em;
  }
  .count-tag {
    font-family: "IBM Plex Mono", monospace;
    font-size: 11px;
    color: var(--ink-soft);
    letter-spacing: 0.04em;
  }

  /* ---------------- ticket stubs ---------------- */
  .tray { display: flex; flex-direction: column; gap: 14px; }

  .ticket {
    position: relative;
    display: flex;
    background: var(--paper-card);
    border: 1px solid var(--rule);
    border-radius: 4px;
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .ticket.new-flash { animation: cardFlash 1.1s ease; }
  @keyframes cardFlash {
    0% { background: #E4EEF6; }
    100% { background: var(--paper-card); }
  }

  .stub-rail {
    flex: none;
    width: 84px;
    padding: 14px 12px;
    display: flex; flex-direction: column; justify-content: space-between;
    border-right: 1px dashed var(--rule);
    background: repeating-linear-gradient(
      var(--paper-shade), var(--paper-shade) 3px, transparent 3px, transparent 7px
    );
  }
  .stub-id { font-family: "IBM Plex Mono", monospace; font-size: 12px; font-weight: 600; }
  .stub-priority {
    font-family: "IBM Plex Mono", monospace;
    font-size: 9px; letter-spacing: 0.05em; text-transform: uppercase;
    color: var(--ink-soft);
  }

  .stub-body { flex: 1; padding: 14px 18px; min-width: 0; }
  .stub-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
  .stub-subject { font-weight: 600; font-size: 14.5px; line-height: 1.3; }
  .stub-customer { color: var(--ink-soft); font-size: 12.5px; margin-top: 2px; }

  .tag-pill {
    flex: none;
    font-family: "IBM Plex Mono", monospace;
    font-size: 10.5px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 100px;
    border: 1px solid var(--rule);
    color: var(--ink-soft);
    white-space: nowrap;
  }

  .stub-draft {
    margin-top: 10px;
    font-size: 13px;
    line-height: 1.5;
    color: var(--ink);
  }
  .placeholder { color: var(--ink-soft); font-style: italic; }

  .stub-footer {
    margin-top: 12px;
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px;
  }

  .steps { display: flex; align-items: center; gap: 4px; }
  .step-dot {
    width: 20px; height: 20px; border-radius: 50%;
    border: 1.5px solid var(--rule);
    display: flex; align-items: center; justify-content: center;
    font-family: "IBM Plex Mono", monospace;
    font-size: 9.5px; font-weight: 600;
    color: var(--ink-soft);
    background: var(--paper-card);
    transition: all 0.25s ease;
  }
  .step-dot.done { border-color: currentColor; color: var(--paper-card); }
  .step-dot.t.done { background: var(--slot-blue); border-color: var(--slot-blue); }
  .step-dot.s.done { background: var(--ochre); border-color: var(--ochre); }
  .step-dot.r.done { background: var(--postal-green); border-color: var(--postal-green); }
  .step-line { width: 10px; height: 1px; background: var(--rule); }
  .digest-route {
    font-family: "IBM Plex Mono", monospace;
    font-size: 10.5px; letter-spacing: 0.03em;
    color: var(--kraft);
  }

  .score { font-family: "IBM Plex Mono", monospace; font-size: 12px; color: var(--ink-soft); }
  .score b { color: var(--ink); font-size: 13px; }

  /* postmark stamp: the signature element, dropped in once an agent chain resolves */
  .postmark {
    position: absolute;
    top: 12px; right: 16px;
    border: 2px solid currentColor;
    border-radius: 50%;
    width: 74px; height: 74px;
    display: flex; align-items: center; justify-content: center;
    text-align: center;
    font-family: "IBM Plex Mono", monospace;
    font-size: 9.5px; font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    line-height: 1.2;
    transform: rotate(-9deg) scale(1);
    animation: stampDown 0.4s cubic-bezier(0.2, 1.4, 0.4, 1);
  }
  .postmark::before {
    content: "";
    position: absolute; inset: 5px;
    border: 1px dashed currentColor;
    border-radius: 50%;
  }
  @keyframes stampDown {
    0% { transform: rotate(-9deg) scale(1.9); opacity: 0; }
    70% { opacity: 1; }
    100% { transform: rotate(-9deg) scale(1); opacity: 1; }
  }
  .postmark.approved { color: var(--postal-green); }
  .postmark.needs_revision { color: var(--stamp-red); }
  .postmark.held_for_digest { color: var(--kraft); }

  .pending-label {
    font-family: "IBM Plex Mono", monospace;
    font-size: 11px; letter-spacing: 0.03em; text-transform: uppercase;
    color: var(--ink-soft);
  }
  .pending-label .dot {
    display: inline-block; width: 6px; height: 6px; border-radius: 50%;
    background: var(--slot-blue); margin-right: 6px;
    animation: pulse 1s infinite;
  }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.25; } }

  /* ---------------- sidebar panels ---------------- */
  .panel {
    position: relative;
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 18px 18px 16px;
    margin-bottom: 24px;
  }
  .digest-panel {
    background: var(--paper-shade);
    border-color: #C9B689;
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    margin-bottom: 0;
  }
  .digest-panel::before {
    content: "";
    position: absolute; top: -1px; left: 50%; transform: translateX(-50%);
    width: 0; height: 0;
    border-left: 26px solid transparent;
    border-right: 26px solid transparent;
    border-top: 16px solid #DED0AC;
  }
  .digest-panel .summary { font-size: 13.5px; line-height: 1.55; margin: 6px 0 12px; }
  .digest-panel ul { margin: 0; padding-left: 18px; font-size: 12.5px; color: var(--ink-soft); }
  .digest-panel li { margin-bottom: 7px; line-height: 1.45; }
  .digest-panel .empty { color: var(--ink-soft); font-size: 13px; font-style: italic; margin: 6px 0; }
  .digest-count {
    font-family: "IBM Plex Mono", monospace;
    font-size: 10.5px; color: var(--kraft); letter-spacing: 0.04em;
  }

  /* ---------------- agent trace: hidden behind a link, shown in an overlay ---------------- */
  .trace-overlay {
    position: fixed;
    inset: 0;
    background: rgba(34, 32, 27, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
    z-index: 50;
  }
  .trace-overlay[hidden] { display: none; }
  .trace-modal {
    background: var(--paper-card);
    border: 1.5px solid var(--ink);
    border-radius: 6px;
    width: min(640px, 100%);
    max-height: 100%;
    display: flex;
    flex-direction: column;
    box-shadow: 0 12px 32px rgba(34,32,27,0.25);
  }
  .trace-modal-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 18px;
    border-bottom: 1.5px solid var(--ink);
  }
  .trace-modal-head h3 {
    font-family: "Fraunces", Georgia, serif;
    font-size: 16px; font-weight: 600; margin: 0;
  }
  .trace-close {
    background: none; border: none; padding: 4px 6px;
    font-family: "IBM Plex Mono", monospace;
    font-size: 13px; color: var(--ink-soft);
    cursor: pointer; text-transform: none; letter-spacing: 0;
  }
  .trace-close:hover { color: var(--ink); }

  .trace-log {
    background: var(--paper-card);
    border-radius: 0 0 6px 6px;
    padding: 4px 18px;
    flex: 1;
    min-height: 200px;
    max-height: 60vh;
    overflow-y: auto;
    font-family: "IBM Plex Mono", monospace;
    font-size: 11.5px;
    line-height: 1.7;
    background-image: repeating-linear-gradient(var(--paper-card) 0 24px, var(--rule) 24px 25px);
    background-position-y: 6px;
  }
  .trace-log .line { padding: 3px 0; white-space: pre-wrap; word-break: break-word; }
  .trace-log .agent-triage { color: var(--slot-blue); }
  .trace-log .agent-specialist { color: var(--ochre); }
  .trace-log .agent-reviewer { color: var(--postal-green); }
  .trace-log .agent-digest { color: var(--kraft); }
  .trace-log .agent-system { color: var(--ink-soft); }
  .trace-log .ts { color: var(--ink-soft); margin-right: 6px; }
  .trace-log .tag { font-weight: 700; margin-right: 4px; }

  @media (max-width: 880px) {
    main { grid-template-columns: 1fr; }
    .right { border-left: none; border-top: 2px solid var(--ink); }
    .ticket { flex-direction: column; }
    .stub-rail { width: auto; flex-direction: row; justify-content: space-between; border-right: none; border-bottom: 1px dashed var(--rule); }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
</head>
<body>

<header>
  <div class="brand">
    <div class="logomark"><span>AI</span></div>
    <div>
      <h1>Hermes</h1>
    </div>
  </div>
  <div class="controls">
    <button class="secondary" id="voicemailBtn">Play voicemail</button>
    <button id="processBtn">Process next ticket</button>
  </div>
</header>

<main>
  <div class="left">
    <div class="section-head">
      <h2>Sorting tray</h2>
      <span class="count-tag" id="trayCount"></span>
    </div>
    <div class="tray" id="ticketsBody"></div>
  </div>

  <div class="right">
    <div class="section-head">
      <h2>Daily digest</h2>
      <button class="trace-link" id="traceOpenBtn"><span class="dot"></span>View agent trace</button>
    </div>
    <div class="panel digest-panel" id="digestPanel">
      <p class="empty">Loading digest&hellip;</p>
    </div>
  </div>
</main>

<div class="trace-overlay" id="traceOverlay" hidden>
  <div class="trace-modal" role="dialog" aria-modal="true" aria-labelledby="traceModalTitle">
    <div class="trace-modal-head">
      <h3 id="traceModalTitle">Agent trace</h3>
      <button class="trace-close" id="traceCloseBtn" aria-label="Close agent trace">Close &times;</button>
    </div>
    <div class="trace-log" id="traceLog"></div>
  </div>
</div>

<script>
const API_BASE = "http://127.0.0.1:8000";

let tickets = [];        // ordered array of ticket objects as returned by /tickets
let ticketsById = {};    // id -> ticket object (live-updated view state)

const ticketsBody = document.getElementById("ticketsBody");
const trayCount = document.getElementById("trayCount");
const processBtn = document.getElementById("processBtn");
const voicemailBtn = document.getElementById("voicemailBtn");
const digestPanel = document.getElementById("digestPanel");
const traceLog = document.getElementById("traceLog");
const traceOverlay = document.getElementById("traceOverlay");
const traceOpenBtn = document.getElementById("traceOpenBtn");
const traceCloseBtn = document.getElementById("traceCloseBtn");

function openTrace() { traceOverlay.hidden = false; traceLog.scrollTop = traceLog.scrollHeight; }
function closeTrace() { traceOverlay.hidden = true; }

traceOpenBtn.addEventListener("click", openTrace);
traceCloseBtn.addEventListener("click", closeTrace);
traceOverlay.addEventListener("click", (e) => { if (e.target === traceOverlay) closeTrace(); });
document.addEventListener("keydown", (e) => { if (e.key === "Escape" && !traceOverlay.hidden) closeTrace(); });

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

function logTrace(agent, text) {
  const time = new Date().toLocaleTimeString([], { hour12: false });
  const line = document.createElement("div");
  line.className = "line agent-" + agent;
  line.innerHTML = `<span class="ts">${time}</span><span class="tag">[${agent}]</span>${text}`;
  traceLog.appendChild(line);
  traceLog.scrollTop = traceLog.scrollHeight;
}

function truncate(str, n) {
  if (!str) return "";
  return str.length > n ? str.slice(0, n - 1) + "…" : str;
}

const STAMP_LABEL = {
  approved: "Approved",
  needs_revision: "Needs\nRevision",
  held_for_digest: "Held for\nDigest",
};

function rowId(ticketId) {
  return "row-" + ticketId.replace(/[^a-zA-Z0-9_-]/g, "_");
}

function stepsHtml(ticket) {
  if (ticket.reply_needed === false) {
    if (ticket.status === "held_for_digest") {
      return `
        <div class="steps">
          <span class="step-dot t done">T</span>
        </div>
        <span class="digest-route">&rarr; routed to digest</span>
      `;
    }
    return `<div class="steps"><span class="step-dot t">T</span></div>`;
  }

  const tDone = !!ticket.tag;
  const sDone = !!(ticket.draft_reply);
  const rDone = ticket.status === "approved" || ticket.status === "needs_revision";

  return `
    <div class="steps">
      <span class="step-dot t ${tDone ? "done" : ""}">T</span>
      <span class="step-line"></span>
      <span class="step-dot s ${sDone ? "done" : ""}">S</span>
      <span class="step-line"></span>
      <span class="step-dot r ${rDone ? "done" : ""}">R</span>
    </div>
  `;
}

function renderRow(ticket, opts = {}) {
  let card = document.getElementById(rowId(ticket.id));
  const isNew = !card;
  if (!card) {
    card = document.createElement("div");
    card.className = "ticket";
    card.id = rowId(ticket.id);
    ticketsBody.appendChild(card);
  }

  const tagHtml = ticket.tag
    ? `<span class="tag-pill">${ticket.tag.replace(/_/g, " ")}</span>`
    : "";

  let draftHtml;
  if (ticket.reply_needed === false && ticket.status === "held_for_digest") {
    draftHtml = `<span class="placeholder">No reply needed &middot; bundled into today's digest.</span>`;
  } else if (ticket.final_reply || ticket.draft_reply) {
    draftHtml = truncate(ticket.final_reply || ticket.draft_reply, 150);
  } else if (ticket.status === "in_progress") {
    draftHtml = `<span class="pending-label"><span class="dot"></span>Drafting reply&hellip;</span>`;
  } else {
    draftHtml = `<span class="placeholder">Waiting in tray.</span>`;
  }

  const scoreHtml = (ticket.score !== null && ticket.score !== undefined)
    ? `<span class="score">Score <b>${ticket.score}</b></span>`
    : "";

  const stampHtml = STAMP_LABEL[ticket.status]
    ? `<div class="postmark ${ticket.status}">${STAMP_LABEL[ticket.status]}</div>`
    : "";

  card.innerHTML = `
    <div class="stub-rail">
      <span class="stub-id">${ticket.id}</span>
      <span class="stub-priority">${ticket.priority || ""}</span>
    </div>
    <div class="stub-body">
      <div class="stub-top">
        <div>
          <div class="stub-subject">${ticket.subject}</div>
          <div class="stub-customer">${ticket.customer || ""}</div>
        </div>
        ${tagHtml}
      </div>
      <div class="stub-draft">${draftHtml}</div>
      <div class="stub-footer">
        ${stepsHtml(ticket)}
        ${scoreHtml}
      </div>
    </div>
    ${stampHtml}
  `;

  if (isNew || opts.flash) {
    card.classList.remove("new-flash");
    void card.offsetWidth; // restart animation
    card.classList.add("new-flash");
  }
}

function updateTrayCount() {
  const done = tickets.filter(t => t.status !== "unprocessed" && t.status !== "in_progress").length;
  trayCount.textContent = `${done} / ${tickets.length} processed`;
}

function renderAllRows() {
  ticketsBody.innerHTML = "";
  tickets.forEach(t => renderRow(t));
  updateTrayCount();
}

async function loadTickets() {
  const res = await fetch(`${API_BASE}/tickets`);
  tickets = await res.json();
  ticketsById = {};
  tickets.forEach(t => { ticketsById[t.id] = t; });
  renderAllRows();
}

async function loadDigest() {
  const res = await fetch(`${API_BASE}/digest`);
  const digest = await res.json();
  if (!digest.ticket_count) {
    digestPanel.innerHTML = `<p class="empty">Nothing held for digest yet.</p>`;
    return;
  }
  const highlights = (digest.highlights || []).map(h => `<li>${h}</li>`).join("");
  digestPanel.innerHTML = `
    <span class="digest-count">${digest.ticket_count} ticket${digest.ticket_count === 1 ? "" : "s"} held</span>
    <p class="summary">${digest.summary || ""}</p>
    <ul>${highlights}</ul>
  `;
}

// Renders the agent chain progressively from trace.steps, even though the
// backend call itself is a single synchronous response. Each step is
// revealed with a short delay so the card (and the trace log) read like a
// live pipeline instead of a single dump.
async function revealTrace(ticket, result) {
  const steps = (result.trace && result.trace.steps) || [];

  ticket.status = "in_progress";
  renderRow(ticket);

  for (const step of steps) {
    await sleep(550);
    const { agent, output } = step;

    if (agent === "triage") {
      ticket.tag = output.tag;
      ticket.priority = output.priority;
      ticket.reply_needed = output.reply_needed;
      logTrace("triage", `tag=${output.tag} priority=${output.priority} reply_needed=${output.reply_needed} — ${output.reasoning || ""}`);
      ticket.status = output.reply_needed ? "in_progress" : "held_for_digest";
      renderRow(ticket);
    } else if (agent === "specialist") {
      ticket.draft_reply = output.draft_reply;
      ticket.status = "in_progress";
      logTrace("specialist", `confidence=${output.confidence} kb_sources=${(output.kb_sources || []).join(",")}`);
      renderRow(ticket);
    } else if (agent === "reviewer") {
      ticket.final_reply = output.final_reply;
      ticket.score = output.score;
      ticket.status = output.status;
      logTrace("reviewer", `score=${output.score} status=${output.status} — ${output.feedback || ""}`);
      renderRow(ticket);
    }
  }

  // Reconcile with whatever the backend ultimately settled on.
  ticket.status = result.status;
  ticket.tag = result.tag;
  ticket.priority = result.priority;
  ticket.draft_reply = result.draft_reply;
  ticket.final_reply = result.final_reply;
  ticket.score = result.score;
  renderRow(ticket, { flash: true });
  updateTrayCount();
}

function nextUnprocessedTicket() {
  return tickets.find(t => t.status === "unprocessed");
}

async function processNextTicket() {
  const ticket = nextUnprocessedTicket();
  if (!ticket) {
    logTrace("system", "no unprocessed tickets remaining");
    processBtn.disabled = true;
    processBtn.textContent = "All tickets processed";
    return;
  }

  processBtn.disabled = true;
  logTrace("system", `processing ${ticket.id}: "${ticket.subject}"`);

  try {
    const res = await fetch(`${API_BASE}/process/${encodeURIComponent(ticket.id)}`, { method: "POST" });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const result = await res.json();
    await revealTrace(ticket, result);
    await loadDigest();
  } catch (err) {
    logTrace("system", `error processing ${ticket.id}: ${err.message}`);
  } finally {
    processBtn.disabled = !!nextUnprocessedTicket() ? false : true;
    if (!nextUnprocessedTicket()) processBtn.textContent = "All tickets processed";
  }
}

async function playVoicemail() {
  voicemailBtn.disabled = true;
  logTrace("system", "transcribing voicemail: demo_voicemail_1…");

  try {
    const res = await fetch(`${API_BASE}/process-voicemail/demo_voicemail_1`, { method: "POST" });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const result = await res.json();

    // Insert the transcribed ticket into the tray immediately, before the
    // agent chain runs, so it visibly "arrives" from the voicemail.
    const placeholder = {
      id: result.id,
      subject: result.subject,
      customer: result.customer,
      status: "in_progress",
      tag: null, draft_reply: null, final_reply: null, score: null,
      reply_needed: null,
    };
    tickets.push(placeholder);
    ticketsById[placeholder.id] = placeholder;
    renderRow(placeholder, { flash: true });
    logTrace("system", `voicemail transcribed → new ticket ${result.id}: "${result.subject}"`);

    await revealTrace(placeholder, result);
    await loadDigest();
  } catch (err) {
    logTrace("system", `error processing voicemail: ${err.message}`);
  } finally {
    voicemailBtn.disabled = false;
    updateTrayCount();
  }
}

processBtn.addEventListener("click", processNextTicket);
voicemailBtn.addEventListener("click", playVoicemail);

(async function init() {
  logTrace("system", "loading inbox…");
  await loadTickets();
  await loadDigest();
  logTrace("system", "ready");
})();
</script>

</body>
</html>
